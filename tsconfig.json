{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true, // Permite importar pacotes CommonJS como o Express
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["jest", "node"],

    // Removido ou alterado para evitar conflitos:
    "verbatimModuleSyntax": false, // Mude para false para ele aceitar imports normais
    "isolatedModules": true,
    "moduleDetection": "force",

    // Organizadores de saída
    "sourceMap": true,
    "declaration": true,
    "rootDir": "./",
    "outDir": "./dist"
  },
  "include": ["src/**/*", "tests/**/*"],
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}
